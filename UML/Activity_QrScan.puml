@startuml Activity Diagram - Quét QR Điểm Danh
title Activity Diagram - Quét QR Điểm Danh

start

:Người dùng mở chức năng quét QR;

if (Đã đăng nhập?) then (Có)
else (Chưa)
  :Chuyển đến màn hình đăng nhập;
  stop
endif

:Hiển thị camera quét QR;
:Yêu cầu quyền truy cập vị trí;

if (Cho phép vị trí?) then (Có)
  :Lấy latitude, longitude;
  :has_location = true;
else (Không)
  :has_location = false;
endif

:Quét QR và lấy token;

:Send request đến server
(token, lat, lng, has_location);

:Server xử lý;

if (Token hợp lệ?) then (Có)
else (Không)
  :Hiển thị QR không hợp lệ;
  stop
endif

if (QR hết hạn?) then (Có)
  :Hiển thị QR hết hạn;
  stop
endif

if (Đã điểm danh?) then (Có)
  :Hiển thị đã điểm danh trước đó;
  stop
endif

if (has_location?) then (Có)

  :Tính khoảng cách;

  if (Khoảng cách < 50m?) then (Có)
    :Status = VALID;
    :Lưu attendance;
    :Cộng điểm;
    :Hiển thị thành công;
  else (Không)
    :Hiển thị không ở gần địa điểm;
    stop
  endif

else (Không)
  :Status = PENDING;
  :Lưu attendance;
  :Hiển thị cần xác minh;
endif

stop
@enduml